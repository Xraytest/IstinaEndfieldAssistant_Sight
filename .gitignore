maa_integration/config/

# Cache files
cache/
**/cache/

# Logs
logs/
core/logs/
**/logs/
*.log

# Debug outputs
debug_output/
debug/
**/debug_output/
**/debug/
.auto_debug/screenshots

# Extracted UI images
extracted_images/

# AI models (large binary GGUF files, ~10GB+)
models/

# Generated output (video, 3D files)
output/

# Page layout exploration data (screenshots, graphs)
page_layouts/

# Training data
training_data/
training_data_augmented/

# Large asset files
assets/audio/
assets/raw_recordings/
assets/screenshots/

# Runtime data (timestamped snapshots)
data/analysis/
data/elements/
data/tasks/
data/events/

# Test files and scripts output
test_screenshot.png
test_tap.png
test_scripts/diagnostic_screenshot.png
**/test_*.png

# Test directories and all test files
tests/
test_scripts/

# Pytest cache
.pytest_cache/
**/.pytest_cache/

# Sensitive files
*.arkpass
config/client_config.json

# Ignore legacy config location (use root only)
IstinaEndfieldAssistant/config/client_config.json

# Session and chat exports
chat_export_*.md
session_*.json

