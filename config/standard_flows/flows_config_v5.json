{
  "version": "5.0",
  "_note": "2026-06-18 基于 OCR+ 模板匹配 +MaaEnd 流程参考完善。整合识别结果与 VLM 决策，保证高可靠性。",
  "recognition_config": {
    "_description": "识别配置：OCR+ 模板匹配 + 颜色匹配",
    "task_icon": {
      "template": "SceneManager/TaskIcon.png",
      "roi": [700, 30, 300, 150],
      "threshold": 5,
      "ocr_expected": ["任务", "Quest", "每日", "每周"],
      "color": {
        "name": "yellow_indicator",
        "roi": [800, 40, 200, 100],
        "lower": [28, 100, 100],
        "upper": [29, 255, 255],
        "min_area": 50,
        "min_contours": 1
      }
    },
    "claim_button": {
      "ocr_expected": ["领取", "Claim", "一键领取", "收取"],
      "color": {
        "name": "yellow_claim_button",
        "roi": [800, 200, 400, 400],
        "lower": [28, 100, 100],
        "upper": [29, 255, 255],
        "min_area": 100,
        "min_contours": 1
      }
    },
    "exit_dialog": {
      "template": "Common/Button/CancelButtonType1.png",
      "roi": [200, 500, 700, 500],
      "threshold": 3,
      "color": {
        "name": "dialog_buttons",
        "roi": [400, 400, 400, 300],
        "lower": [28, 100, 100],
        "upper": [29, 255, 255],
        "min_area": 50,
        "min_contours": 2
      }
    }
  },
  "vlm_prompts": {
    "_description": "VLM Prompt 模板：基于识别结果的决策",
    "navigation_confirm": "你是明日方舟终末地游戏自动化助手。根据识别结果确认是否应该点击目标元素。\n\n当前任务：{task}\n识别结果：{recognition_results}\n参考坐标：{reference_coords}\n\n请分析并回答（仅回答 YES 或 NO）：\n- YES: 应该点击，识别结果支持\n- NO: 不应该点击，识别结果不支持或画面异常",
    "page_verify": "你是明日方舟终末地游戏自动化助手。根据画面特征验证当前页面类型。\n\n预期页面：{expected_page}\n画面特征：left_bar={left_bar}, green={green}, brightness={brightness}, gold={gold_contours}\n识别结果：{recognition_results}\n\n请判断页面类型（仅回答一个词）：world/quest_panel/event_panel/menu/base/character/loading/title/dialog/other",
    "action_decision": "你是明日方舟终末地游戏自动化助手。根据识别结果决定点击位置。\n\n当前任务：{task}\n识别结果：{recognition_results}\n参考坐标：{reference_coords}\n\n返回 JSON（仅 JSON）：{{\"action\": \"tap/back/wait/none\", \"coords\": [x, y], \"reason\": \"原因\"}}\n\n决策规则：1)OCR 优先 2) 模板匹配次之 3) 颜色匹配再次 4) 参考坐标降级",
    "status_analysis": "你是明日方舟终末地游戏自动化助手。分析当前页面状态。\n\n当前页面：{page}\n任务目标：{goal}\n画面特征：left_bar={left_bar}, green={green}, brightness={brightness}\n\n返回 JSON（仅 JSON）：{{\"can_proceed\": true/false, \"status\": \"ready/pending/loading/error\", \"next_action\": \"tap/swipe/wait/back\", \"reason\": \"原因\"}}"
  },
  "page_features": {
    "_description": "页面类型特征定义",
    "world": {"left_bar_min": 30, "left_bar_max": 50, "green_min": 100, "brightness_min": 80, "brightness_max": 120, "gold_min": 5, "gold_max": 15},
    "quest_panel": {"left_bar_min": 40, "left_bar_max": 60, "green_min": 0, "green_max": 50, "brightness_min": 70, "brightness_max": 100, "gold_min": 22, "gold_max": 50},
    "exit_dialog": {"left_bar_min": 0, "left_bar_max": 15, "green_min": 0, "green_max": 0, "brightness_min": 100, "brightness_max": 999, "gold_min": 2, "gold_max": 5},
    "title_loading": {"left_bar_min": 150, "left_bar_max": 999, "green_min": 0, "green_max": 0, "brightness_min": 180, "brightness_max": 999, "gold_min": 0, "gold_max": 2}
  },
  "flows": {
    "daily_quest": {
      "enabled": true,
      "description": "完成每日任务并领取奖励（MaaEnd DijiangRewards 模式 + 识别增强）",
      "_maarend_ref": "DijiangRewards: Navigation→StatusCheck→ScrollFind→Claim→Back",
      "recognition_enabled": true,
      "steps": [
        {
          "id": "ensure_world",
          "action": "check",
          "expect": "world",
          "desc": "确保在探索界面（世界地图）",
          "feature_check": {"left_bar": [30, 50], "green": [100, 999]},
          "recovery": {"if_exit_dialog": "click_cancel_or_restart", "if_title": "click_center_and_wait"}
        },
        {
          "id": "open_quest_panel",
          "action": "tap",
          "target": "task_icon",
          "use_recognition": true,
          "recognition": "task_icon",
          "fallback_coords": [860, 80],
          "wait": 4,
          "desc": "打开任务面板（使用识别结果决定点击位置）",
          "vlm_verify": true,
          "vlm_prompt": "page_verify",
          "vlm_params": {"expected_page": "quest_panel"},
          "success_criteria": {"page_type": "quest_panel", "gold_contours_min": 22}
        },
        {
          "id": "verify_quest_panel",
          "action": "check",
          "expect": "quest_panel",
          "desc": "验证任务面板已打开",
          "feature_check": {"left_bar": [40, 60], "gold": [22, 999]},
          "timeout": 5,
          "recovery": {"if_not_quest_panel": "retry_tap_task_icon"}
        },
        {
          "id": "scroll_daily_tasks",
          "action": "swipe",
          "start": [540, 800],
          "end": [540, 400],
          "duration": 500,
          "desc": "滑动查找每日任务（MaaEnd GrowthChamberTargetNotFound）",
          "max_retries": 3,
          "retry_delay": 1
        },
        {
          "id": "check_daily_status",
          "action": "check",
          "desc": "检查每日任务状态",
          "recognition": {
            "ocr_expected": ["可领取", "领取", "完成", "Claim"],
            "roi": [400, 200, 800, 400]
          }
        },
        {
          "id": "claim_daily_rewards",
          "action": "claim",
          "target": "claim_button",
          "use_recognition": true,
          "recognition": "claim_button",
          "fallback_coords": [810, 900],
          "desc": "一键领取每日任务奖励（使用识别结果）",
          "wait": 2
        },
        {
          "id": "verify_claim",
          "action": "wait",
          "wait": 2,
          "desc": "等待领取动画完成"
        },
        {
          "id": "close_quest_panel",
          "action": "back",
          "wait": 2,
          "desc": "返回探索界面（keyevent 4）"
        },
        {
          "id": "verify_world_return",
          "action": "check",
          "expect": "world",
          "desc": "验证已返回世界地图",
          "feature_check": {"left_bar": [30, 50], "green": [100, 999]},
          "timeout": 5
        }
      ]
    },
    "weekly_quest": {
      "enabled": true,
      "description": "完成周常任务并领取奖励（MaaEnd BAKER 模式 + 识别增强）",
      "_maarend_ref": "BAKER: SwitchTab→SwipeFilter→FilterUnread→Claim",
      "recognition_enabled": true,
      "steps": [
        {
          "id": "ensure_world",
          "action": "check",
          "expect": "world",
          "desc": "确保在探索界面"
        },
        {
          "id": "open_quest_panel",
          "action": "tap",
          "target": "task_icon",
          "use_recognition": true,
          "recognition": "task_icon",
          "fallback_coords": [860, 80],
          "wait": 4,
          "desc": "打开任务面板"
        },
        {
          "id": "verify_quest_panel",
          "action": "check",
          "expect": "quest_panel",
          "desc": "验证任务面板"
        },
        {
          "id": "switch_to_weekly",
          "action": "tap",
          "coords": [810, 300],
          "wait": 3,
          "desc": "切换到周常标签页",
          "vlm_verify": true,
          "vlm_prompt": "page_verify",
          "vlm_params": {"expected_page": "quest_panel_weekly"}
        },
        {
          "id": "scroll_weekly_list",
          "action": "swipe",
          "start": [540, 900],
          "end": [540, 500],
          "duration": 600,
          "desc": "滑动查找周常任务（MaaEnd BakerSwipeFilter）",
          "max_retries": 3
        },
        {
          "id": "check_weekly_status",
          "action": "check",
          "desc": "检查周常任务状态（MaaEnd BakerFilterUnread）",
          "recognition": {
            "ocr_expected": ["可领取", "领取", "Claim"],
            "roi": [400, 200, 800, 400]
          }
        },
        {
          "id": "claim_weekly_rewards",
          "action": "claim",
          "target": "claim_button",
          "use_recognition": true,
          "recognition": "claim_button",
          "fallback_coords": [810, 900],
          "desc": "领取周常奖励"
        },
        {
          "id": "return_world",
          "action": "back",
          "wait": 2,
          "desc": "返回探索界面"
        }
      ]
    },
    "auto_restart_on_stuck": {
      "enabled": true,
      "description": "无响应时自动重启游戏",
      "conditions": {
        "same_screen_count": 3,
        "same_screen_threshold": 0.95,
        "exit_dialog_persist": true
      },
      "action": "restart_game",
      "game_package": "com.hypergryph.endfield",
      "wait_after_restart": 15
    }
  },
  "execution": {
    "default_temperature": 0.1,
    "max_retries": 3,
    "retry_delay": 2,
    "_note": "无超时机制，等待用户确认或自动恢复"
  }
}
