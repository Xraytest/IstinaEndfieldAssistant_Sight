{
  "version": "1.0",
  "root_level": "INFO",
  "format": "%(asctime)s [%(levelname)s] %(name)s: %(message)s",
  "handlers": {
    "console": {
      "enabled": true,
      "level": "INFO"
    },
    "file": {
      "enabled": true,
      "level": "DEBUG",
      "path": "logs/iea_local.log",
      "rotation": {
        "max_bytes": 10485760,
        "backup_count": 5
      }
    }
  },
  "categories": {
    "MAIN": "INFO",
    "ADB": "INFO",
    "GUI": "INFO",
    "VLM": "INFO"
  }
}
