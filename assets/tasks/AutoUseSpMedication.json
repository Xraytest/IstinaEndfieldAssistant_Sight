        "AutoUseSpMedicationUseCount": {
            "type": "input",
            "label": "$option.AutoUseSpMedicationUseCount.label",
            "description": "$option.AutoUseSpMedicationUseCount.description",
            "inputs": [
                {
                    "name": "UseCount",
                    "label": "$option.AutoUseSpMedicationUseCount.inputs.UseCount.label",
                    "description": "$option.AutoUseSpMedicationUseCount.inputs.UseCount.description",
                    "default": "99",
                    "pipeline_type": "int",
                    "pattern_msg": "$option.AutoUseSpMedicationUseCount.inputs.UseCount.pattern_msg",
                    "verify": "^([1-9]\\d?)$"
                }
            ],
            "pipeline_override": {
                "AutoUseSpMedicationLoop": {
                    "max_hit": "{UseCount}"
                }
            }
        },
        "AutoUseSpMedicationMaxSanity": {
            "type": "input",
            "label": "$option.AutoUseSpMedicationMaxSanity.label",
            "description": "$option.AutoUseSpMedicationMaxSanity.description",
            "inputs": [
                {
                    "name": "MaxSanity",
                    "label": "$option.AutoUseSpMedicationMaxSanity.inputs.MaxSanity.label",
                    "description": "$option.AutoUseSpMedicationMaxSanity.inputs.MaxSanity.description",
                    "default": "9999",
                    "pipeline_type": "int",
                    "pattern_msg": "$option.AutoUseSpMedicationMaxSanity.inputs.MaxSanity.pattern_msg",
                    "verify": "^([1-9]\\d{0,3})$"
                }
            ],
            "pipeline_override": {
                "AutoUseSpMedicationCheckSanity": {
                    "recognition": {
                        "param": {
                            "custom_recognition_param": {
                                "expression": "{AutoUseSpMedicationCurrentSanity}<{MaxSanity}"
                            }
                        }
                    }
                },
                "AutoUseSpMedicationCheckSanityEnough": {
                    "recognition": {
                        "param": {
                            "custom_recognition_param": {
                                "expression": "{AutoUseSpMedicationCurrentSanity}>={MaxSanity}"
                            }
                        }
                    }
                }
            }
        }
